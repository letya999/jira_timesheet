# =============================================================================
# Caddy Configuration for Jira Timesheet (Production)
# Frontend: http://{$APP_DOMAIN}:8080
# Backend:  http://{$API_DOMAIN}:8080
# =============================================================================

# Frontend (React App)
http://{$APP_DOMAIN}:8080 {
    # API запросы проксируются напрямую к backend (JWT auth на стороне FastAPI)
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Всё остальное - React SPA
    handle {
        reverse_proxy web:8501
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# Backend (FastAPI API)
http://{$API_DOMAIN}:8080 {
    reverse_proxy backend:8000

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
