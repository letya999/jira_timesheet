# =============================================================================
# Production Environment - Example
# =============================================================================

# Domains
APP_DOMAIN=jira-timesheet.yourdomain.com
API_DOMAIN=jira-timesheet-api.yourdomain.com

# Database
POSTGRES_USER=jira_timesheet_admin
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=timesheet_prod
DATABASE_URL=postgresql+asyncpg://jira_timesheet_admin:secure_password@db:5432/timesheet_prod

# Redis
REDIS_URL=redis://redis:6379/0

# Jira Integration
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=admin@your-company.com
JIRA_API_TOKEN=your_token

# Security
SECRET_KEY=generate_a_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
